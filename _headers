# Cloudflare Pages headers — applied at the edge for every response.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# --- Security & SEO headers (all routes) ---
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-Frame-Options: SAMEORIGIN
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  # COEP: require-corp is the strictest mode, but it would break cross-origin
  # subresources that don't return CORP/CORS headers (ads, flag CDN images).
  # `credentialless` allows those without sending credentials, which is what we want.
  Cross-Origin-Embedder-Policy: credentialless
  # CSP — starts in Report-Only so any unintended block surfaces in DevTools/reports
  # without breaking the page. After ~1 week of zero reports, rename the header to
  # `Content-Security-Policy` to enforce.
  # 'unsafe-inline' is required because:
  #   - Per-language pages inject <script>window.__CMA_LANG__=…</script>
  #   - index.html has 1 inline <script> (ads idle-loader) and 1 inline style (noscript fallback)
  # Everything else is locked down: object/base/form-action denied, frame-ancestors self.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.sheetjs.com https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.google.com https://*.doubleclick.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.googlesyndication.com https://*.google.com https://*.doubleclick.net https://*.gstatic.com; font-src 'self' data:; connect-src 'self' https://pagead2.googlesyndication.com https://*.google.com https://*.doubleclick.net; frame-src https://googleads.g.doubleclick.net https://*.googlesyndication.com; child-src https://googleads.g.doubleclick.net https://*.googlesyndication.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests

# --- HTML: short cache, must revalidate so updates roll out fast ---
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/*/
  Cache-Control: public, max-age=0, must-revalidate

# --- Static assets: immutable for 1 year (cache-busted by ?v= query) ---
/css/*
  Cache-Control: public, max-age=31536000, immutable
/js/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# --- Sitemap & robots: short cache for crawler freshness ---
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8
/robots.txt
  Cache-Control: public, max-age=3600
